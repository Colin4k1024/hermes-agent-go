# ─── Hermes Agent — Quickstart Configuration ────────────────────────────────
# Copy this file to .env and fill in your LLM credentials.
# Only the three LLM variables are required to run the isolation tests.

# ─── LLM Provider (required) ─────────────────────────────────────────────────
# The base URL WITHOUT /v1 — the server appends /v1/chat/completions internally.

# MiniMax (default — change model as needed)
LLM_API_URL=https://api.minimaxi.com
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=MiniMax-M2.7-highspeed

# ── Alternatives: uncomment one block below and comment out the MiniMax block ──

# OpenAI
# LLM_API_URL=https://api.openai.com
# LLM_API_KEY=sk-your-openai-key
# LLM_MODEL=gpt-4o-mini

# Anthropic (via OpenAI-compat proxy)
# LLM_API_URL=https://api.anthropic.com
# LLM_API_KEY=sk-ant-your-key
# LLM_MODEL=claude-haiku-4-5-20251001

# Ollama (local)
# LLM_API_URL=http://host.docker.internal:11434
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.2

# ─── Admin Bootstrap Token ───────────────────────────────────────────────────
# Used by bootstrap.sh to create tenants and API keys.
# Can be any string for local dev — change in production.
HERMES_ACP_TOKEN=dev-bootstrap-token
